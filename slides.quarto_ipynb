      "source": [
        "---\n",
        "\n",
        "## 4 — Top-20 mots par auteur (hors stopwords)\n"
      ],
      "id": "2bbe8fdd"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "top20 = (\n",
        "    words_sdf\n",
        "    .groupBy(\"author\",\"courant\",\"word\")\n",
        "    .agg(F.sum(\"freq\").alias(\"total_freq\"))\n",
        "    .withColumn(\"rk\", F.rank().over(Window.partitionBy(\"author\").orderBy(F.desc(\"total_freq\"))))\n",
        "    .filter(F.col(\"rk\") <= 20)\n",
        "    .toPandas()\n",
        ")\n",
        "\n",
        "authors = sorted(top20[\"author\"].unique())\n",
        "ncols   = 3\n",
        "nrows   = math.ceil(len(authors) / ncols)\n",
        "\n",
        "fig = make_subplots(rows=nrows, cols=ncols, subplot_titles=authors,\n",
        "    vertical_spacing=0.08, horizontal_spacing=0.08)\n",
        "\n",
        "for i, author in enumerate(authors):\n",
        "    r, c = divmod(i, ncols)\n",
        "    sub  = top20[top20[\"author\"] == author].sort_values(\"total_freq\")\n",
        "    courant = sub[\"courant\"].iloc[0]\n",
        "    fig.add_trace(\n",
        "        go.Bar(x=sub[\"total_freq\"], y=sub[\"word\"], orientation=\"h\",\n",
        "            marker_color=COLOR_COURANT.get(courant,\"#888\"),\n",
        "            name=author, showlegend=False),\n",
        "        row=r+1, col=c+1)\n",
        "\n",
        "fig.update_layout(template=\"plotly_white\", height=280*nrows,\n",
        "    font=dict(size=9), margin=dict(t=40))\n",
        "fig.show()"
      ],
      "id": "09b522ec",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
