    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: setup\n",
        "#| include: false\n",
        "\n",
        "import os, re, math, time, warnings\n",
        "from pathlib import Path\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import plotly.express as px\n",
        "import plotly.graph_objects as go\n",
        "from plotly.subplots import make_subplots\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "from pyspark.sql import SparkSession\n",
        "from pyspark.sql import functions as F\n",
        "from pyspark.sql.types import (\n",
        "    StringType, StructType, StructField,\n",
        "    LongType, DoubleType, ArrayType, IntegerType\n",
        ")\n",
        "from pyspark.sql.window import Window\n",
        "\n",
        "N_CORES = os.cpu_count() or 4\n",
        "\n",
        "spark = (\n",
        "    SparkSession.builder\n",
        "    .appName(\"Stylometry19C\")\n",
        "    .master(f\"local[{N_CORES}]\")\n",
        "    .config(\"spark.sql.shuffle.partitions\", str(N_CORES))\n",
        "    .config(\"spark.default.parallelism\",    str(N_CORES))\n",
        "    .config(\"spark.sql.adaptive.enabled\",                       \"true\")\n",
        "    .config(\"spark.sql.adaptive.coalescePartitions.enabled\",    \"true\")\n",
        "    .config(\"spark.sql.adaptive.skewJoin.enabled\",              \"true\")\n",
        "    .config(\"spark.serializer\",              \"org.apache.spark.serializer.KryoSerializer\")\n",
        "    .config(\"spark.kryoserializer.buffer.max\",\"512m\")\n",
        "    .config(\"spark.driver.memory\",  \"4g\")\n",
        "    .config(\"spark.executor.memory\",\"4g\")\n",
        "    .getOrCreate()\n",
        ")\n",
        "spark.sparkContext.setLogLevel(\"ERROR\")\n",
        "\n",
        "DATA_DIR    = Path(\"DATA\")\n",
        "PARQUET_DIR = Path(\"_outdir/parquet\")\n",
        "PARQUET_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "COLOR_COURANT = {\"Romantisme\": \"#4C72B0\", \"Réalisme\": \"#DD8452\"}\n",
        "COLOR_AUTHOR = {\n",
        "    \"Balzac\":         \"#1f77b4\",\n",
        "    \"Hugo\":           \"#aec7e8\",\n",
        "    \"Stendhal\":       \"#2ca02c\",\n",
        "    \"Sand\":           \"#98df8a\",\n",
        "    \"Flaubert\":       \"#d62728\",\n",
        "    \"Zola\":           \"#ff9896\",\n",
        "    \"Voltaire\":       \"#9467bd\",\n",
        "    \"Chateaubriand\":  \"#8c564b\",\n",
        "    \"Gautier\":        \"#e377c2\",\n",
        "}"
      ],
      "id": "setup",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: metadata-and-etl\n",
        "#| include: false\n",
        "\n",
        "METADATA = {\n",
        "    \"Adieu.txt\":                   (\"Adieu\",                           \"Balzac\", \"Réalisme\"),\n",
        "    \"Albert-Savarus.txt\":          (\"Albert Savarus\",                  \"Balzac\", \"Réalisme\"),\n",
        "    \"Autre-etude-de-femme.txt\":    (\"Autre étude de femme\",            \"Balzac\", \"Réalisme\"),\n",
        "    \"Avant-propos.txt\":            (\"Avant-propos — Comédie humaine\",  \"Balzac\", \"Réalisme\"),\n",
        "    \"Beatrix.txt\":                 (\"Béatrix\",                         \"Balzac\", \"Réalisme\"),\n",
        "    \"Cesar-Birotteau.txt\":         (\"César Birotteau\",                 \"Balzac\", \"Réalisme\"),\n",
        "    \"Combien-l_amour-revient.txt\": (\"A combien l'amour revient\",       \"Balzac\", \"Réalisme\"),\n",
        "    \"Deux-jeunes-mariees.txt\":     (\"Memoires de deux jeunes mariees\", \"Balzac\", \"Réalisme\"),\n",
        "    \"El-verdugo.txt\":              (\"El Verdugo\",                      \"Balzac\", \"Réalisme\"),\n",
        "    \"Esquisse-d_homme-d_affaires.txt\": (\"Esquisse d'homme d'affaires\", \"Balzac\", \"Réalisme\"),\n",
        "    \"Esther-heureuse.txt\":             (\"Esther heureuse\",             \"Balzac\", \"Réalisme\"),\n",
        "    \"Etude-de-femme.txt\":              (\"Etude de femme\",              \"Balzac\", \"Réalisme\"),\n",
        "    \"Eugenie-Grandet.txt\":             (\"Eugenie Grandet\",             \"Balzac\", \"Réalisme\"),\n",
        "    \"Eve-et-David.txt\":                (\"Eve et David\",                \"Balzac\", \"Réalisme\"),\n",
        "    \"Facino-Cane.txt\":                 (\"Facino Cane\",                 \"Balzac\", \"Réalisme\"),\n",
        "    \"Ferragus.txt\":                    (\"Ferragus\",                    \"Balzac\", \"Réalisme\"),\n",
        "    \"Gambara.txt\":                     (\"Gambara\",                     \"Balzac\", \"Réalisme\"),\n",
        "    \"Gaudissart-II.txt\":               (\"Gaudissart II\",               \"Balzac\", \"Réalisme\"),\n",
        "    \"Gobseck.txt\":                     (\"Gobseck\",                     \"Balzac\", \"Réalisme\"),\n",
        "    \"Honorine.txt\":                    (\"Honorine\",                    \"Balzac\", \"Réalisme\"),\n",
        "    \"Jesus-Christ-en-Flandre.txt\":     (\"Jesus-Christ en Flandre\",    \"Balzac\", \"Réalisme\"),\n",
        "    \"La-bourse.txt\":                   (\"La Bourse\",                   \"Balzac\", \"Réalisme\"),\n",
        "    \"La-cousine-Bette.txt\":            (\"La Cousine Bette\",            \"Balzac\", \"Réalisme\"),\n",
        "    \"hugo_ndp.txt\":                (\"Notre-Dame de Paris\",             \"Hugo\",   \"Romantisme\"),\n",
        "    \"hugo_qvt.txt\":                (\"Quatrevingt-Treize\",              \"Hugo\",   \"Romantisme\"),\n",
        "    \"hugo_ldj.txt\":                (\"Le Dernier Jour d'un Condamne\",   \"Hugo\",   \"Romantisme\"),\n",
        "    \"stendhal_le_rouge_et_le_noir.txt\":    (\"Le Rouge et le Noir\",       \"Stendhal\", \"Réalisme\"),\n",
        "    \"stendhal_la_chartreuse_de_parme.txt\": (\"La Chartreuse de Parme\",    \"Stendhal\", \"Réalisme\"),\n",
        "    \"stendhal_souvenirs_d_egoisme.txt\":    (\"Souvenirs d'egotisme\",      \"Stendhal\", \"Réalisme\"),\n",
        "    \"stendhal_de_l_amour.txt\":             (\"De l'Amour\",                \"Stendhal\", \"Réalisme\"),\n",
        "    \"sand_lpf.txt\":                (\"La Petite Fadette\",               \"Sand\",   \"Romantisme\"),\n",
        "    \"sand_gabriel.txt\":            (\"Gabriel\",                         \"Sand\",   \"Romantisme\"),\n",
        "    \"flaubert_madame_bovary.txt\":       (\"Madame Bovary\",        \"Flaubert\", \"Réalisme\"),\n",
        "    \"flaubert_bouvard_et_pecuchet.txt\": (\"Bouvard et Pecuchet\",  \"Flaubert\", \"Réalisme\"),\n",
        "    \"flaubert_trois_contes.txt\":        (\"Trois Contes\",          \"Flaubert\", \"Réalisme\"),\n",
        "    \"flaubert_un_coeur_simple.txt\":     (\"Un Coeur simple\",       \"Flaubert\", \"Réalisme\"),\n",
        "    \"Zola_germinal.txt\":           (\"Germinal\",                       \"Zola\",   \"Réalisme\"),\n",
        "    \"Zola_l_assomoir.txt\":         (\"L'Assommoir\",                    \"Zola\",   \"Réalisme\"),\n",
        "    \"Zola_lourdes.txt\":            (\"Lourdes\",                        \"Zola\",   \"Réalisme\"),\n",
        "    \"Maupassant_candide.txt\":      (\"Candide\",                        \"Voltaire\", \"Romantisme\"),\n",
        "    \"chateaubriand_vie_de_rance.txt\": (\"Vie de Rance\",               \"Chateaubriand\", \"Romantisme\"),\n",
        "    \"gautier_clarimonde.txt\":      (\"La Morte amoureuse (Clarimonde)\", \"Gautier\", \"Romantisme\"),\n",
        "    \"gautier_emau.txt\":            (\"Emaux et Camees\",                 \"Gautier\", \"Romantisme\"),\n",
        "    \"gautier_menagerie_intime.txt\":(\"Menagerie intime\",                \"Gautier\", \"Romantisme\"),\n",
        "    \"gautier_sacountala.txt\":      (\"Sacountala\",                      \"Gautier\", \"Romantisme\"),\n",
        "}\n",
        "\n",
        "START_PAT = re.compile(r\"\\*{3}\\s*START OF[^\\*]*\\*{3}\", re.IGNORECASE)\n",
        "END_PAT   = re.compile(r\"\\*{3}\\s*END OF[^\\*]*\\*{3}\",   re.IGNORECASE)\n",
        "ORNAMENT  = re.compile(r\"^\\s*[\\*\\-\\=]{3,}\\s*$\", re.MULTILINE)\n",
        "ROMAN_CH  = re.compile(\n",
        "    r\"^\\s*(M{0,3})(CM|CD|D?C{0,3})(XC|XL|L?X{0,3})(IX|IV|V?I{0,3})\\s*\\.?\\s*$\",\n",
        "    re.IGNORECASE | re.MULTILINE\n",
        ")\n",
        "\n",
        "def clean_text(text: str) -> str:\n",
        "    m = START_PAT.search(text)\n",
        "    if m: text = text[m.end():]\n",
        "    m = END_PAT.search(text)\n",
        "    if m: text = text[:m.start()]\n",
        "    text = ORNAMENT.sub(\"\", text)\n",
        "    text = ROMAN_CH.sub(\"\", text)\n",
        "    return text.strip()\n",
        "\n",
        "UPLOAD_DIR = Path(\"/mnt/user-data/uploads\")\n",
        "\n",
        "records = []\n",
        "for fname, (title, author, courant) in METADATA.items():\n",
        "    candidates = [DATA_DIR / fname, UPLOAD_DIR / fname]\n",
        "    path = next((p for p in candidates if p.exists()), None)\n",
        "    if path is None:\n",
        "        continue\n",
        "    raw     = path.read_text(encoding=\"utf-8\", errors=\"replace\")\n",
        "    cleaned = clean_text(raw)\n",
        "    records.append((fname, title, author, courant, cleaned))\n",
        "\n",
        "schema = StructType([\n",
        "    StructField(\"filename\", StringType(), False),\n",
        "    StructField(\"title\",    StringType(), False),\n",
        "    StructField(\"author\",   StringType(), False),\n",
        "    StructField(\"courant\",  StringType(), False),\n",
        "    StructField(\"text\",     StringType(), False),\n",
        "])\n",
        "\n",
        "corpus_sdf = spark.createDataFrame(records, schema)\n",
        "corpus_sdf.cache()\n",
        "N_DOCS = corpus_sdf.count()\n",
        "\n",
        "meta_rows   = [(f, t, a, c) for f,(t,a,c) in METADATA.items()]\n",
        "meta_schema = StructType([\n",
        "    StructField(\"filename\", StringType()),\n",
        "    StructField(\"title\",    StringType()),\n",
        "    StructField(\"author\",   StringType()),\n",
        "    StructField(\"courant\",  StringType()),\n",
        "])\n",
        "df_meta = spark.createDataFrame(meta_rows, meta_schema)"
      ],
      "id": "metadata-and-etl",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: stats-base\n",
        "#| include: false\n",
        "\n",
        "syllable_udf = F.udf(\n",
        "    lambda t: int(sum(\n",
        "        len(re.findall(r'[aeiouyàâäéèêëîïôöùûüœ]+', w, re.I))\n",
        "        for w in (t or \"\").split()\n",
        "    )), LongType()\n",
        ")\n",
        "type_token_udf = F.udf(\n",
        "    lambda t: float(len(set((t or \"\").lower().split())) /\n",
        "               max(len((t or \"\").split()), 1)), DoubleType()\n",
        ")\n",
        "avg_word_len_udf = F.udf(\n",
        "    lambda t: float(np.mean([len(w) for w in (t or \"\").split()])\n",
        "                    if (t or \"\").split() else 0.0), DoubleType()\n",
        ")\n",
        "\n",
        "stats_sdf = (\n",
        "    corpus_sdf\n",
        "    .withColumn(\"n_chars\",     F.length(\"text\"))\n",
        "    .withColumn(\"n_words\",     F.size(F.split(\"text\", r\"\\s+\")))\n",
        "    .withColumn(\"n_sentences\", F.size(F.split(\"text\", r\"[.!?]+\")))\n",
        "    .withColumn(\"n_syllables\", syllable_udf(\"text\"))\n",
        "    .withColumn(\"ttr\",         type_token_udf(\"text\"))\n",
        "    .withColumn(\"avg_word_len\",avg_word_len_udf(\"text\"))\n",
        "    .drop(\"text\")\n",
        ")\n",
        "stats_sdf.cache()\n",
        "\n",
        "@F.udf(DoubleType())\n",
        "def udf_fk(nw, ns, nsyl):\n",
        "    if not nw or not ns or nw == 0 or ns == 0: return 0.0\n",
        "    return round(206.835 - 1.015*(nw/ns) - 84.6*(nsyl/nw), 3)\n",
        "\n",
        "@F.udf(DoubleType())\n",
        "def udf_km(nw, ns, nsyl):\n",
        "    if not nw or not ns or nw == 0 or ns == 0: return 0.0\n",
        "    return round(209.835 - 2.048*(nw/ns) - 64.3*(nsyl/nw), 3)\n",
        "\n",
        "read_sdf = (\n",
        "    stats_sdf\n",
        "    .withColumn(\"fk\", udf_fk(\"n_words\",\"n_sentences\",\"n_syllables\"))\n",
        "    .withColumn(\"km\", udf_km(\"n_words\",\"n_sentences\",\"n_syllables\"))\n",
        ")\n",
        "read_sdf.cache()\n",
        "read_pd = read_sdf.toPandas()"
      ],
      "id": "stats-base",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: word-frequencies\n",
        "#| include: false\n",
        "\n",
        "STOPWORDS_FR = {\n",
        "    \"le\",\"la\",\"les\",\"de\",\"du\",\"des\",\"un\",\"une\",\"et\",\"en\",\"a\",\"au\",\"aux\",\n",
        "    \"il\",\"elle\",\"ils\",\"elles\",\"je\",\"tu\",\"nous\",\"vous\",\"on\",\"se\",\"sa\",\"son\",\"ses\",\n",
        "    \"que\",\"qui\",\"qu\",\"ne\",\"pas\",\"plus\",\"par\",\"sur\",\"dans\",\"avec\",\"est\",\"etait\",\n",
        "    \"pour\",\"mais\",\"ou\",\"donc\",\"or\",\"ni\",\"car\",\"ce\",\"cet\",\"cette\",\"ces\",\"mon\",\n",
        "    \"ma\",\"mes\",\"ton\",\"ta\",\"tes\",\"lui\",\"leur\",\"leurs\",\"y\",\"si\",\"comme\",\"bien\",\n",
        "    \"tout\",\"tous\",\"meme\",\"tres\",\"aussi\",\"toute\",\"toutes\",\"etre\",\"avoir\",\"fait\",\n",
        "    \"dit\",\"peut\",\"dont\",\"quel\",\"quelle\",\"quels\",\"quelles\",\"d\",\"l\",\"j\",\"m\",\"n\",\"s\",\"c\"\n",
        "}\n",
        "\n",
        "words_sdf = (\n",
        "    corpus_sdf\n",
        "    .select(\"filename\",\"title\",\"author\",\"courant\",\n",
        "            F.explode(F.split(F.lower(F.regexp_replace(\"text\", r\"[^\\w\\s]\", \" \")), r\"\\s+\")).alias(\"word\"))\n",
        "    .filter(F.length(\"word\") > 2)\n",
        "    .filter(~F.col(\"word\").isin(STOPWORDS_FR))\n",
        "    .groupBy(\"filename\",\"title\",\"author\",\"courant\",\"word\")\n",
        "    .agg(F.count(\"*\").alias(\"freq\"))\n",
        ")\n",
        "words_sdf.cache()\n",
        "\n",
        "w_spec = Window.partitionBy(\"filename\").orderBy(F.desc(\"freq\"))\n",
        "ranked_sdf = (\n",
        "    words_sdf\n",
        "    .withColumn(\"rank\",     F.rank().over(w_spec))\n",
        "    .withColumn(\"log_rank\", F.log10(\"rank\"))\n",
        "    .withColumn(\"log_freq\", F.log10(F.col(\"freq\") + 1))\n",
        ")\n",
        "ranked_sdf.cache()\n",
        "zipf_pd = ranked_sdf.filter(F.col(\"rank\") <= 200).toPandas()\n",
        "zipf_pd[\"log_rank\"] = np.log10(zipf_pd[\"rank\"])\n",
        "zipf_pd[\"log_freq\"] = np.log10(zipf_pd[\"freq\"] + 1)"
      ],
      "id": "word-frequencies",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: dialog-segmentation\n",
        "#| include: false\n",
        "\n",
        "dialog_udf    = F.udf(lambda t: sum(1 for l in (t or \"\").split('\\n')\n",
        "                                    if re.match(r'^\\s*[«\"—–\\-]', l)), LongType())\n",
        "narration_udf = F.udf(lambda t: sum(1 for l in (t or \"\").split('\\n')\n",
        "                                    if l.strip() and not re.match(r'^\\s*[«\"—–\\-]', l)), LongType())\n",
        "\n",
        "seg_sdf = (\n",
        "    corpus_sdf\n",
        "    .withColumn(\"dialog_lines\",    dialog_udf(\"text\"))\n",
        "    .withColumn(\"narration_lines\", narration_udf(\"text\"))\n",
        "    .select(\"title\",\"author\",\"courant\",\"dialog_lines\",\"narration_lines\")\n",
        ")\n",
        "seg_sdf.cache()\n",
        "seg_pd = seg_sdf.toPandas()\n",
        "seg_pd[\"total\"]      = seg_pd[\"dialog_lines\"] + seg_pd[\"narration_lines\"]\n",
        "seg_pd[\"pct_dialog\"] = (seg_pd[\"dialog_lines\"] / seg_pd[\"total\"].replace(0, 1) * 100).round(1)"
      ],
      "id": "dialog-segmentation",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: sliding-windows\n",
        "#| include: false\n",
        "\n",
        "VOWELS = re.compile(r'[aeiouyàâäéèêëîïôöùûüœ]+', re.I)\n",
        "\n",
        "def sliding_fk(text, window=500, step=250):\n",
        "    words = text.split()\n",
        "    out = []\n",
        "    for i in range(0, len(words) - window, step):\n",
        "        chunk = words[i:i+window]\n",
        "        n_s   = max(1, sum(1 for w in chunk if re.search(r'[.!?]$', w)))\n",
        "        n_syl = sum(len(VOWELS.findall(w)) for w in chunk)\n",
        "        asl   = window / n_s\n",
        "        asw   = n_syl  / window\n",
        "        fk    = round(206.835 - 1.015*asl - 84.6*asw, 2)\n",
        "        km    = round(209.835 - 2.048*asl - 64.3*asw, 2)\n",
        "        out.append((i, fk, km))\n",
        "    return out\n",
        "\n",
        "sliding_schema = ArrayType(StructType([\n",
        "    StructField(\"pos\", LongType()),\n",
        "    StructField(\"fk\",  DoubleType()),\n",
        "    StructField(\"km\",  DoubleType()),\n",
        "]))\n",
        "sliding_udf = F.udf(lambda t: sliding_fk(t, 500, 250) if t else [], sliding_schema)\n",
        "\n",
        "sliding_sdf = (\n",
        "    corpus_sdf\n",
        "    .filter(F.size(F.split(\"text\", r\"\\s+\")) > 40000)\n",
        "    .select(\"title\",\"author\",\"courant\", sliding_udf(\"text\").alias(\"wins\"))\n",
        "    .select(\"title\",\"author\",\"courant\", F.explode(\"wins\").alias(\"w\"))\n",
        "    .select(\"title\",\"author\",\"courant\",\n",
        "            F.col(\"w.pos\").alias(\"pos\"),\n",
        "            F.col(\"w.fk\").alias(\"fk\"),\n",
        "            F.col(\"w.km\").alias(\"km\"))\n",
        ")\n",
        "sliding_sdf.cache()\n",
        "sliding_pd = sliding_sdf.toPandas()"
      ],
      "id": "sliding-windows",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: zipf-regression\n",
        "#| include: false\n",
        "\n",
        "from scipy import stats as scipy_stats\n",
        "\n",
        "reg_rows = []\n",
        "for (fname, author, courant, title), grp in zipf_pd.groupby([\"filename\",\"author\",\"courant\",\"title\"]):\n",
        "    if len(grp) < 10: continue\n",
        "    slope, intercept, r, p, se = scipy_stats.linregress(grp[\"log_rank\"], grp[\"log_freq\"])\n",
        "    reg_rows.append({\n",
        "        \"title\":title,\"author\":author,\"courant\":courant,\n",
        "        \"slope\":round(slope,3),\"intercept\":round(intercept,3),\"r2\":round(r**2,3)\n",
        "    })\n",
        "reg_df = pd.DataFrame(reg_rows)"
      ],
      "id": "zipf-regression",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "\n",
        "# Analyse Stylométrique du XIXe siècle {background-color=\"#1E2761\"}\n",
        "\n",
        "::: {style=\"color: #CADCFC; font-size: 1.1em; margin-top: 1em;\"}\n",
        "**Projet 1 · PySpark · Spark NLP**\n",
        "\n",
        "Krista Carla Sevi · Mick-Wanderly Laveus · Leon Lafosse\n",
        ":::\n",
        "\n",
        "::: {style=\"color: #aaa; font-size: 0.85em; margin-top: 2em;\"}\n",
