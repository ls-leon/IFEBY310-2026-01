      "source": [
        "---\n",
        "title: \"Analyse Stylométrique du XIXe siècle\"\n",
        "subtitle: \"Projet 1 · PySpark · Spark NLP\"\n",
        "author: \"Krista Carla Sevi · Mick-Wanderly Laveus · Leon Lafosse\"\n",
        "date: today\n",
        "lang: fr\n",
        "format:\n",
        "  revealjs:\n",
