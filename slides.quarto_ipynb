    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "\n",
        "## 4 — Distance stylistique entre auteurs\n"
      ],
      "id": "3732cb8d"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "style_feats = read_pd.groupby(\"author\")[[\"fk\",\"km\",\"ttr\",\"avg_word_len\"]].mean()\n",
        "scaler = StandardScaler()\n",
        "X = scaler.fit_transform(style_feats)\n",
        "\n",
        "n = len(style_feats)\n",
        "dist_mat = np.zeros((n, n))\n",
        "for i in range(n):\n",
        "    for j in range(n):\n",
        "        dist_mat[i,j] = np.sqrt(np.sum((X[i]-X[j])**2))\n",
        "\n",
        "authors_list = list(style_feats.index)\n",
        "fig = px.imshow(\n",
        "    dist_mat, x=authors_list, y=authors_list,\n",
        "    color_continuous_scale=\"Blues_r\",\n",
        "    labels={\"color\":\"Distance\"},\n",
        "    template=\"plotly_white\", height=460,\n",
        "    text_auto=\".2f\",\n",
        ")\n",
        "fig.update_layout(font=dict(size=11), margin=dict(t=20))\n",
        "fig.show()"
      ],
      "id": "bda78cdb",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "\n",
        "# 5 — Expérience Spark & Formats Big Data {background-color=\"#065A82\"}\n",
        "\n",
        "::: {style=\"color: #CADCFC; font-size: 0.9em;\"}\n",
        "Configuration Spark · Shuffles · Benchmark formats\n",
        ":::\n",
        "\n",
        "---\n",
        "\n",
        "## 5 — Shuffles critiques dans le pipeline\n"
      ],
      "id": "ed0012ed"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "shuffle_data = pd.DataFrame({\n",
        "    \"Opération\": [\n",
        "        \"groupBy(filename, word).agg(count)\",\n",
        "        \"rank().over(Window.partitionBy(filename))\",\n",
        "        \"write.partitionBy(courant)\",\n",
        "        \"Window glissante (sliding_fk)\",\n",
        "        \"join(broadcast(df_meta))\",\n",
        "    ],\n",
        "    \"Impact\": [\"Élevé\", \"Modéré\", \"Modéré\", \"Modéré\", \"Nul\"],\n",
        "    \"Score\":  [3, 2, 2, 2, 0],\n",
        "})\n",
        "\n",
        "fig = px.bar(\n",
        "    shuffle_data.sort_values(\"Score\"),\n",
        "    x=\"Score\", y=\"Opération\",\n",
        "    color=\"Impact\",\n",
        "    color_discrete_map={\"Élevé\":\"#d62728\",\"Modéré\":\"#ff7f0e\",\"Nul\":\"#2ca02c\"},\n",
        "    orientation=\"h\",\n",
        "    labels={\"Score\":\"Impact (0=nul, 3=élevé)\",\"Opération\":\"Opération\"},\n",
        "    template=\"plotly_white\", height=380,\n",
        ")\n",
        "fig.update_layout(legend_title=\"Impact\", font=dict(size=11),\n",
        "    margin=dict(l=320, t=20, b=40))\n",
        "fig.show()"
      ],
      "id": "be0ac164",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "\n",
        "## 5 — Benchmark formats de stockage\n"
      ],
      "id": "bd6ba4b1"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import shutil\n",
        "\n",
        "fmt_results = []\n",
        "for fmt in [\"parquet\",\"orc\",\"json\",\"csv\"]:\n",
        "    out = str(PARQUET_DIR.parent / f\"bench_{fmt}\")\n",
        "    shutil.rmtree(out, ignore_errors=True)\n",
        "\n",
        "    t0 = time.time()\n",
        "    if fmt == \"csv\":\n",
        "        stats_sdf.write.mode(\"overwrite\").option(\"header\",\"true\").csv(out)\n",
        "    elif fmt == \"json\":\n",
        "        stats_sdf.write.mode(\"overwrite\").json(out)\n",
        "    elif fmt == \"orc\":\n",
        "        stats_sdf.write.mode(\"overwrite\").orc(out)\n",
        "    else:\n",
        "        stats_sdf.write.mode(\"overwrite\").parquet(out)\n",
        "    t_write = round(time.time()-t0, 3)\n",
        "\n",
        "    t0 = time.time()\n",
        "    if fmt == \"csv\":\n",
        "        spark.read.option(\"header\",\"true\").csv(out).count()\n",
        "    elif fmt == \"json\":\n",
        "        spark.read.json(out).count()\n",
        "    elif fmt == \"orc\":\n",
        "        spark.read.orc(out).count()\n",
        "    else:\n",
        "        spark.read.parquet(out).count()\n",
        "    t_read = round(time.time()-t0, 3)\n",
        "\n",
        "    size_b = sum(\n",
        "        os.path.getsize(os.path.join(dp, f))\n",
        "        for dp, _, fs in os.walk(out) for f in fs\n",
        "    )\n",
        "    fmt_results.append({\n",
        "        \"Format\": fmt.upper(),\n",
        "        \"Ecriture (s)\": t_write,\n",
        "        \"Lecture (s)\":  t_read,\n",
        "        \"Taille (KB)\":  round(size_b/1024, 1),\n",
        "    })\n",
        "\n",
        "fmt_df = pd.DataFrame(fmt_results)\n",
        "\n",
        "fig = make_subplots(rows=1, cols=3,\n",
        "    subplot_titles=[\"Ecriture (s)\", \"Lecture (s)\", \"Taille (KB)\"])\n",
        "\n",
        "colors_fmt = {\"PARQUET\":\"#2ca02c\",\"ORC\":\"#1f77b4\",\"JSON\":\"#d62728\",\"CSV\":\"#ff7f0e\"}\n",
        "\n",
        "for col_i, metric in enumerate([\"Ecriture (s)\", \"Lecture (s)\", \"Taille (KB)\"], start=1):\n",
        "    fig.add_trace(\n",
        "        go.Bar(x=fmt_df[\"Format\"], y=fmt_df[metric],\n",
        "            text=fmt_df[metric], textposition=\"outside\",\n",
        "            marker_color=[colors_fmt.get(f,\"#888\") for f in fmt_df[\"Format\"]],\n",
        "            showlegend=False),\n",
        "        row=1, col=col_i)\n",
        "\n",
        "fig.update_layout(template=\"plotly_white\", height=420,\n",
        "    font=dict(size=11), margin=dict(t=40))\n",
        "fig.show()"
      ],
