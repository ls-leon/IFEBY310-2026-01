        "\n",
        "## 4 — Loi de Zipf : Romantisme vs Réalisme\n"
      ],
      "id": "bac2ed83"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "fig = make_subplots(rows=1, cols=2,\n",
        "    subplot_titles=[\"Romantisme\",\"Réalisme\"], shared_yaxes=True)\n",
        "\n",
        "for col_idx, courant in enumerate([\"Romantisme\",\"Réalisme\"], start=1):\n",
        "    sub = zipf_pd[zipf_pd[\"courant\"] == courant]\n",
        "    seen = set()\n",
        "    for title, grp in sub.groupby(\"title\"):\n",
        "        author = grp[\"author\"].iloc[0]\n",
        "        show = author not in seen\n",
        "        seen.add(author)\n",
        "        fig.add_trace(\n",
        "            go.Scatter(x=grp[\"log_rank\"], y=grp[\"log_freq\"],\n",
        "                mode=\"lines\", name=author if show else title,\n",
        "                line=dict(width=1, color=COLOR_AUTHOR.get(author,\"#888\")),\n",
        "                opacity=0.6, legendgroup=author, showlegend=show),\n",
        "            row=1, col=col_idx)\n",
        "\n",
        "fig.update_xaxes(title_text=\"log10(rang)\", row=1, col=1)\n",
        "fig.update_xaxes(title_text=\"log10(rang)\", row=1, col=2)\n",
        "fig.update_yaxes(title_text=\"log10(fréquence)\", row=1, col=1)\n",
        "fig.update_layout(template=\"plotly_white\", height=430,\n",
        "    legend_title=\"Auteur\", font=dict(size=11), margin=dict(t=40))\n",
        "fig.show()"
      ],
      "id": "02a2d5f0",
      "execution_count": null,
      "outputs": []
    },
